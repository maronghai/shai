# ---------------------------------------------------------------------------
# Build artifacts
# Zig 目录条目为历史遗留；项目目前是纯 Bash，保留以备改名后复用
# ---------------------------------------------------------------------------
.zig-cache/
.zigmod/
zig-out/

# Compiled objects / shared libs
*.dll
*.dylib
*.exe
*.exp
*.lib
*.o
*.obj
*.pdb
*.so

# ---------------------------------------------------------------------------
# Runtime data (created by ai-agent.sh)
# ---------------------------------------------------------------------------
.data/
.tmp/
.last-response.txt

# ---------------------------------------------------------------------------
# Tool / IDE state
# ---------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
# opencode metadata + sqlite db
.codegraph/
# Claude Code state
.claude/

# ---------------------------------------------------------------------------
# Editor backups / merge artifacts
# ---------------------------------------------------------------------------
*.bak
*.orig
*.rej
*.swo
*.swp
*~
*#
.#*

# ---------------------------------------------------------------------------
# OS cruft
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
._*
.directory
Desktop.ini
ehthumbs.db
Thumbs.db
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# Misc safety nets
# ---------------------------------------------------------------------------
# any stray test/agent logs
*.log
# generic temp files
*.tmp
# ad-hoc test scripts at repo root
tmp_*.sh
# secrets at root
.env
.env.*
*.sqlite
*.sqlite3
.claude
.codegraph
.editorconfig
.shellcheckrc
.gitattributes